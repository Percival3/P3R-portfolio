---
import '../styles/global.css';
import { getRelativeLocaleUrl } from 'astro:i18n';
import ForestPresence from '../components/ForestPresence.astro';
import PageTransitionReceiver from '../components/PageTransitionReceiver.astro';
import PageTransitionStateScript from '../components/PageTransitionStateScript.astro';
import P3RLanguageSwitch from '../components/P3RLanguageSwitch.astro';

interface Props {
  title: string;
  lang: string;
  section: 'blog' | 'research' | 'gallery' | 'about';
  canonical?: string;
  detailThemeToggle?: boolean;
}

const { title, lang, section, canonical, detailThemeToggle = false } = Astro.props;

const homeUrl      = getRelativeLocaleUrl(lang, '');
const blogUrl      = getRelativeLocaleUrl(lang, 'blog');
const researchUrl  = getRelativeLocaleUrl(lang, 'research');
const galleryUrl   = getRelativeLocaleUrl(lang, 'gallery');
const aboutUrl     = getRelativeLocaleUrl(lang, 'about');

type ArcItem = { key: string; label: string; url: string };
const arcNavMap: Record<string, ArcItem[]> = {
  zh: [
    { key: 'blog',     label: '博客',       url: blogUrl },
    { key: 'research', label: '学术',       url: researchUrl },
    { key: 'gallery',  label: '作品',       url: galleryUrl },
    { key: 'about',    label: '关于',       url: aboutUrl },
  ],
  en: [
    { key: 'blog',     label: 'Blog',       url: blogUrl },
    { key: 'research', label: 'Research',   url: researchUrl },
    { key: 'gallery',  label: 'Gallery',    url: galleryUrl },
    { key: 'about',    label: 'About',      url: aboutUrl },
  ],
  ja: [
    { key: 'blog',     label: 'ブログ',     url: blogUrl },
    { key: 'research', label: '研究',       url: researchUrl },
    { key: 'gallery',  label: 'ギャラリー', url: galleryUrl },
    { key: 'about',    label: '私について', url: aboutUrl },
  ],
};
const navItems = arcNavMap[lang] ?? arcNavMap.zh;
const sectionLabel = navItems.find(i => i.key === section)?.label ?? section.toUpperCase();
const detailThemeTextMap = {
  zh: {
    label: '阅读主题',
    clearing: '林隙',
    nocturne: '夜林',
  },
  en: {
    label: 'Reading tone',
    clearing: 'Clearing',
    nocturne: 'Nocturne',
  },
  ja: {
    label: '読書トーン',
    clearing: '林隙',
    nocturne: '夜林',
  },
} as const;
const detailThemeText = detailThemeTextMap[lang as keyof typeof detailThemeTextMap] ?? detailThemeTextMap.zh;
const mobileControlTextMap = {
  zh: {
    nav: '栏目',
    theme: '主题',
  },
  en: {
    nav: 'Menu',
    theme: 'Tone',
  },
  ja: {
    nav: '項目',
    theme: 'トーン',
  },
} as const;
const mobileControlText = mobileControlTextMap[lang as keyof typeof mobileControlTextMap] ?? mobileControlTextMap.zh;
---

<!doctype html>
<html lang={lang} class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <link rel="icon" type="image/svg+xml" href="/template-mark.svg" />
  {canonical && <link rel="canonical" href={canonical} />}
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,700;0,900;1,400;1,700;1,900&family=Barlow:ital,wght@0,400;0,700;1,400;1,700&family=IBM+Plex+Mono:wght@400;500&family=Noto+Sans+SC:wght@400;500;700&family=Noto+Sans+JP:wght@400;500;700&family=Noto+Serif+SC:wght@500;700&family=Noto+Serif+JP:wght@500;700&display=swap"
  />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV" crossorigin="anonymous" />
  <PageTransitionStateScript />
  {detailThemeToggle && (
    <script is:inline>
      (() => {
        const key = 'curved-chaos-detail-theme';
        const stored = typeof localStorage !== 'undefined' ? localStorage.getItem(key) : null;
        const theme = stored === 'nocturne' ? 'nocturne' : 'clearing';
        document.documentElement.dataset.detailTheme = theme;
      })();
    </script>
  )}
</head>

<body style="margin:0;overflow:hidden;background:var(--p3r-ice-body-bg);">

  <!-- ripple overlay -->
  <div class="p3r-ripple" id="ripple1"></div>
  <div class="p3r-ripple" id="ripple2"></div>
  <PageTransitionReceiver />

  <div class="p3r-screen page-transition-stage">

    <!-- ── background decoration ── -->
    <div class="content-bg">
      <canvas id="c-canvas"></canvas>
      <div class="content-field"></div>
      <ForestPresence />
      <div class="bg-tri t1"></div>
      <div class="bg-tri t2"></div>
      <div class="bg-diamond d1"></div>
      <div class="bg-diamond d2"></div>
      <div class="bg-diamond d3"></div>
      <div class="bg-section-name">{sectionLabel}</div>
    </div>

    <div class="content-topbar"></div>
    <div class="content-botbar"></div>
    <div class="c-scan"></div>
    <div class="vignette"></div>
    <div class="p3r-corner tl"></div>
    <div class="p3r-corner tr"></div>
    <div class="p3r-corner bl"></div>
    <div class="p3r-corner br"></div>

    <!-- back to home -->
    <a class="nav-back" href={homeUrl}>◀ HOME</a>
    <div class="layout-lang-dock">
      <P3RLanguageSwitch lang={lang} />
    </div>

    <!-- ── left: content ── -->
    <main class="content-main">
      <div class="sec-scroll">
        <slot />
      </div>
    </main>

    <!-- ── right: arc nav ── -->
    <nav class="content-nav" id="contentNav">
      {navItems.map((item) => (
        <a
          class:list={['cnav-item', { active: item.key === section }]}
          href={item.url}
          data-url={item.url}
        >
          {item.label}
        </a>
      ))}
      <div class="nav-footer">SYS_VER: 3.0.RELOAD<br />SYNC: 100%</div>
    </nav>
    <button
      type="button"
      class="mobile-nav-toggle"
      id="mobileNavToggle"
      aria-controls="contentNav"
      aria-expanded="false"
      aria-label={mobileControlText.nav}
    >
      <span class="mobile-nav-toggle__text">{mobileControlText.nav}</span>
    </button>

    {detailThemeToggle && (
      <div class="detail-theme-dock">
        <button
          type="button"
          class="detail-theme-toggle"
          data-detail-theme-toggle
          aria-expanded="false"
          aria-label={detailThemeText.label}
        >
          <span class="detail-theme-toggle__text">{mobileControlText.theme}</span>
        </button>
        <div class="detail-theme-label">{detailThemeText.label}</div>
        <div class="detail-theme-switch" role="group" aria-label={detailThemeText.label}>
          <button
            type="button"
            class="detail-theme-button"
            data-detail-theme-button
            data-theme-value="clearing"
            aria-pressed="true"
          >
            {detailThemeText.clearing}
          </button>
          <button
            type="button"
            class="detail-theme-button"
            data-detail-theme-button
            data-theme-value="nocturne"
            aria-pressed="false"
          >
            {detailThemeText.nocturne}
          </button>
        </div>
      </div>
    )}

    <div class="content-commands">
      <div class="ca">Navigate</div>
      <div class="ck">CLICK · ESC Home · ↑↓ Switch</div>
    </div>

  </div>
</body>
</html>

<style is:global>
  /* ══════════════════════════════════════════
     P3R CONTENT LAYOUT — GLOBAL STYLES
  ══════════════════════════════════════════ */

  /* Force P3R shell variable context */
  body {
    --adaptive-text-strong:  var(--p3r-ice-white);
    --adaptive-text-body:    var(--p3r-ice-text-body);
    --adaptive-text-muted:   var(--p3r-ice-text-muted);
    --adaptive-text-soft:    var(--p3r-ice-text-dim);
    --adaptive-link:         var(--p3r-ice-link);
    --adaptive-accent-text:  var(--p3r-ice-accent-bright);
    --adaptive-accent-text-hover: var(--p3r-ice-white);
    --adaptive-blockquote-bg: var(--p3r-ice-panel-bg-soft);
    --adaptive-blockquote-border: var(--p3r-ice-accent-border-strong);
    --adaptive-hr:           var(--p3r-ice-divider-strong);
    --adaptive-inline-code:  var(--p3r-ice-accent-bright);
    --adaptive-inline-code-bg: var(--p3r-ice-chip-bg);
    --component-accent:      var(--p3r-ice-accent);
    --component-accent-strong: var(--p3r-ice-accent-bright);
    --component-accent-muted: var(--p3r-ice-text-muted);
    --component-accent-border: var(--p3r-ice-accent-border);
    --component-accent-border-strong: var(--p3r-ice-accent-border-strong);
    --component-accent-divider: var(--p3r-ice-divider);
    --component-accent-divider-strong: var(--p3r-ice-divider-strong);
    --surface-frame-bg:      transparent;
    --surface-frame-border:  var(--p3r-ice-divider);
    --surface-frame-shadow:  none;
    --surface-panel-bg:      var(--p3r-ice-panel-bg);
    --surface-panel-border:  var(--p3r-ice-accent-border);
    --surface-panel-shadow:  0 4px 16px rgba(0,0,0,0.28);
    --surface-chip-bg:       var(--p3r-ice-chip-bg);
    --surface-chip-border:   var(--p3r-ice-accent-border);
    --surface-primary-button-bg: var(--p3r-ice-cta-bg);
    --surface-primary-button-text: var(--p3r-ice-white);
    --surface-primary-button-shadow: 0 10px 24px rgba(0,0,0,0.28);
    --icon-button-bg:        var(--p3r-ice-chip-bg);
    --icon-button-border:    var(--p3r-ice-accent-border);
    --icon-button-border-hover: var(--p3r-ice-accent-border-strong);
    --icon-button-text:      var(--p3r-ice-accent-bright);
    --icon-button-shadow:    inset 0 1px 0 rgba(168,250,246,0.1), 0 4px 16px rgba(0,0,0,0.24);
    --icon-button-shadow-hover: inset 0 1px 0 rgba(168,250,246,0.14), 0 8px 24px rgba(0,0,0,0.32);
  }

  /* Ripple overlay */
  .p3r-ripple {
    position: fixed; inset: 0;
    z-index: 9000; pointer-events: none;
    clip-path: circle(0px at 50% 50%);
  }
  #ripple1 { background: #ffffff; }
  #ripple2 { background: var(--p3r-ice-ripple); opacity: 0.72; }

  /* ── Full-screen shell ── */
  .p3r-screen {
    position: fixed; inset: 0; overflow: hidden;
    font-family: 'Barlow Condensed', 'Barlow', sans-serif;
    background: var(--p3r-ice-shell-gradient);
  }
  .p3r-screen::before {
    content: ''; position: absolute; inset: 0; z-index: 0;
    background-image:
      linear-gradient(var(--p3r-ice-shell-grid) 1px, transparent 1px),
      linear-gradient(90deg, var(--p3r-ice-shell-grid) 1px, transparent 1px);
    background-size: 46px 46px;
    pointer-events: none;
  }
  .p3r-screen::after {
    content: ''; position: absolute; z-index: 0; pointer-events: none;
    width: 70%; aspect-ratio: 1; right: -10%; top: 50%; transform: translateY(-50%);
    background: radial-gradient(circle, var(--p3r-ice-shell-halo) 0%, transparent 65%);
  }

  /* ── Scanlines ── */
  .c-scan {
    position: absolute; inset: 0; z-index: 3; pointer-events: none;
    background: repeating-linear-gradient(
      0deg, transparent 0px, transparent 3px,
      rgba(0,0,0,.03) 3px, rgba(0,0,0,.03) 4px
    );
  }
  .vignette {
    position: absolute; inset: 0; z-index: 3; pointer-events: none;
    box-shadow: inset 0 0 100px rgba(0,18,20,.5);
  }

  /* ── Corner accents ── */
  .p3r-corner { position: absolute; width: 14px; height: 14px; z-index: 25; }
  .p3r-corner.tl { top:14px;    left:14px;  border-top:2px solid var(--p3r-ice-accent); border-left:2px solid var(--p3r-ice-accent); }
  .p3r-corner.tr { top:14px;    right:14px; border-top:2px solid var(--p3r-ice-accent); border-right:2px solid var(--p3r-ice-accent); }
  .p3r-corner.bl { bottom:14px; left:14px;  border-bottom:2px solid var(--p3r-ice-accent); border-left:2px solid var(--p3r-ice-accent); }
  .p3r-corner.br { bottom:14px; right:14px; border-bottom:2px solid var(--p3r-ice-accent); border-right:2px solid var(--p3r-ice-accent); }

  /* ── Back button ── */
  .nav-back {
    position: absolute;
    top: calc(var(--viewport-safe-top) + 20px);
    left: calc(var(--viewport-safe-left) + 28px);
    z-index: 40;
    font-weight: 700; font-style: italic; font-size: .9rem;
    color: rgba(255,255,255,.6); cursor: pointer; letter-spacing: .07em;
    transition: color .15s; text-decoration: none;
  }
  .nav-back:hover { color: #ffffff; }

  .layout-lang-dock {
    position: absolute;
    top: calc(var(--viewport-safe-top) + 48px);
    left: calc(var(--viewport-safe-left) + 28px);
    z-index: 40;
  }

  /* ── Background decoration ── */
  .content-bg { position: absolute; inset: 0; z-index: 2; pointer-events: none; overflow: hidden; --forest-presence-opacity: 0.6; }
  #c-canvas { position: absolute; inset: 0; width: 100%; height: 100%; }

  .content-field {
    position: absolute; inset: 0; z-index: 1; pointer-events: none;
    background: var(--p3r-ice-field-gradient);
  }

  .bg-section-name {
    position: absolute; left: -15px; bottom: -20px;
    font-family: 'Barlow Condensed', 'Barlow', sans-serif;
    font-weight: 900; font-style: italic;
    font-size: clamp(180px, 23vw, 300px);
    line-height: .82; letter-spacing: -.05em;
    color: rgba(255,255,255,.07);
    white-space: nowrap; user-select: none;
    pointer-events: none; z-index: 2;
    -webkit-mask-image: linear-gradient(to top, black 0%, black 45%, transparent 100%);
    mask-image: linear-gradient(to top, black 0%, black 45%, transparent 100%);
  }

  .content-topbar {
    position: absolute; top: 0; left: 0; right: 0; height: 3px; z-index: 30; pointer-events: none;
    background: var(--p3r-ice-topbar);
  }
  .content-botbar {
    position: absolute; bottom: 0; left: 0; right: 0; height: 2px; z-index: 30; pointer-events: none;
    background: var(--p3r-ice-botbar);
  }

  /* Diamond debris */
  .bg-diamond { position: absolute; pointer-events: none; z-index: 5; background: var(--p3r-ice-accent-bright); transform: rotate(45deg); }
  .bg-diamond.d1 { width:14px; height:14px; right:430px; bottom:22%; opacity:.70; animation: diamondDrift 5.5s ease-in-out infinite alternate; }
  .bg-diamond.d2 { width:9px;  height:9px;  right:395px; bottom:15%; opacity:.50; animation: diamondDrift 7s ease-in-out infinite alternate; animation-delay:1.2s; }
  .bg-diamond.d3 { width:18px; height:18px; right:470px; bottom:10%; opacity:.55; animation: diamondDrift 6.2s ease-in-out infinite alternate; animation-delay:2.5s; }
  @keyframes diamondDrift {
    0%   { transform: rotate(45deg) translateY(0)     scale(1); }
    100% { transform: rotate(48deg) translateY(-14px) scale(0.85); }
  }

  /* Diagonal bands */
  .bg-tri { position: absolute; pointer-events: none; background: white; z-index: 4; }
  .bg-tri.t1 { width:58%; height:100%; left:18%; clip-path:polygon(22% 0,36% 0,24% 100%,8% 100%); opacity:.10; }
  .bg-tri.t2 { width:58%; height:100%; left:18%; clip-path:polygon(37% 0,40% 0,28% 100%,25% 100%); opacity:.14; }

  /* ── Content main ── */
  .content-main {
    position: absolute;
    top: 0; left: 0; bottom: 0;
    right: 330px; /* leave room for arc nav */
    z-index: 10; overflow: hidden;
    display: flex; align-items: stretch;
    padding: 52px 0 52px 52px;
  }

  .sec-scroll {
    flex: 1; overflow-y: auto;
    padding-right: 24px;
    font-family: 'Noto Sans SC', 'Noto Sans JP', sans-serif;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
  }
  .sec-scroll::-webkit-scrollbar { width: 4px; }
  .sec-scroll::-webkit-scrollbar-track { background: rgba(255,255,255,.06); }
  .sec-scroll::-webkit-scrollbar-thumb { background: rgba(255,255,255,.3); border-radius: 4px; }

  /* ── Arc nav (4 items, R=240px, angles ±60°, ±20°) ── */
  .content-nav {
    position: absolute; right: 0; top: 0;
    width: 300px; height: 100%;
    z-index: 20; pointer-events: none;
  }
  .cnav-item {
    position: absolute; right: 0; top: 50%;
    font-weight: 900; font-style: italic;
    font-size: 1.35rem;
    color: var(--p3r-ice-accent-bright);
    white-space: nowrap; cursor: pointer; pointer-events: all;
    text-align: right; line-height: 1; padding: 2px 5px;
    text-decoration: none; display: block;
    transition: font-size .3s cubic-bezier(.16,1,.3,1), color .15s, opacity .3s, text-shadow .15s;
    text-shadow: var(--p3r-ice-hover-glow);
  }
  /* Arc positions: R=240, angles ±60° and ±20° */
  .cnav-item:nth-child(1) { right:108px; transform:translateY(calc(-198px - 50%)); }
  .cnav-item:nth-child(2) { right:208px; transform:translateY(calc(-78px  - 50%)); }
  .cnav-item:nth-child(3) { right:208px; transform:translateY(calc( 78px  - 50%)); }
  .cnav-item:nth-child(4) { right:108px; transform:translateY(calc( 198px - 50%)); }

  .cnav-item.active {
    color: var(--p3r-ice-ink) !important;
    font-size: 2.6rem !important;
    z-index: 1; text-shadow: none; opacity: 1 !important;
    letter-spacing: .02em;
  }
  .cnav-item.active::before {
    content: ''; position: absolute;
    top: -4px; bottom: -4px; left: -14px; right: -10px;
    background: var(--p3r-ice-highlight);
    clip-path: polygon(10px 0, 100% 0, calc(100% - 10px) 100%, 0 100%);
    transform: skewX(-5deg); z-index: -1;
  }
  .cnav-item:not(.active):hover {
    color: #ffffff;
    text-shadow: 0 0 22px rgba(255,255,255,.8), 0 0 44px rgba(49,214,208,.42);
  }

  .nav-footer {
    position: absolute; right: 22px; bottom: 28px;
    color: rgba(255,255,255,.25); font-family: 'Barlow', sans-serif;
    font-size: .6rem; letter-spacing: .1em; text-align: right; line-height: 1.8;
    pointer-events: none; z-index: 1;
  }

  /* ── Bottom commands ── */
  .content-commands {
    position: absolute;
    right: calc(var(--viewport-safe-right) + 28px);
    bottom: calc(var(--viewport-safe-bottom) + 22px);
    z-index: 30;
    text-align: right;
  }
  .content-commands .ca { font-weight: 700; font-style: italic; font-size: 1.05rem; color: rgba(255,255,255,.9); letter-spacing: .05em; }
  .content-commands .ck { font-family: 'Barlow', sans-serif; font-size: .6rem; color: rgba(255,255,255,.5); letter-spacing: .1em; border-top: 1px solid rgba(255,255,255,.18); padding-top: 4px; margin-top: 3px; }

  .detail-theme-dock {
    position: absolute;
    right: calc(var(--viewport-safe-right) + 28px);
    bottom: calc(var(--viewport-safe-bottom) + 88px);
    z-index: 30;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.45rem;
  }

  .detail-theme-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--p3r-ice-text-muted);
  }

  .detail-theme-switch {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    padding: 0.28rem;
    border: 1px solid var(--p3r-ice-accent-border);
    background: var(--p3r-ice-panel-bg-soft);
    box-shadow: 0 12px 24px rgba(0,0,0,0.18);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    clip-path: polygon(10px 0, 100% 0, calc(100% - 10px) 100%, 0 100%);
  }

  .detail-theme-button {
    appearance: none;
    border: none;
    min-width: 6.3rem;
    padding: 0.46rem 0.92rem;
    background: transparent;
    color: var(--p3r-ice-text-muted);
    font-family: 'Barlow Condensed', 'Barlow', sans-serif;
    font-size: 0.92rem;
    font-style: italic;
    font-weight: 700;
    letter-spacing: 0.05em;
    cursor: pointer;
    clip-path: polygon(10px 0, 100% 0, calc(100% - 10px) 100%, 0 100%);
    transition: color 180ms ease, background 180ms ease, transform 180ms ease, box-shadow 180ms ease;
  }

  .detail-theme-button:hover {
    color: var(--p3r-ice-white);
  }

  .detail-theme-button.is-active {
    background: var(--p3r-ice-highlight);
    color: var(--p3r-ice-ink);
    box-shadow: 0 6px 16px rgba(0,0,0,0.14);
    transform: translateY(-1px);
  }

  .mobile-nav-toggle,
  .detail-theme-toggle {
    display: none;
    appearance: none;
    border: 1px solid var(--p3r-ice-accent-border);
    background: rgba(4, 20, 24, 0.72);
    color: var(--p3r-ice-accent-bright);
    box-shadow: 0 14px 28px rgba(0,0,0,0.24);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    cursor: pointer;
  }

  .mobile-nav-toggle__text,
  .detail-theme-toggle__text {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.66rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  :global(html[data-detail-theme='nocturne']) .content-bg {
    --forest-presence-opacity: 0.74;
  }

  :global(html[data-detail-theme='nocturne']) .vignette {
    box-shadow: inset 0 0 130px rgba(0, 5, 10, 0.72);
  }

  /* ══════════════════════════════════════════
     CONTENT STYLE OVERRIDES
     Make existing editorial classes look good on the ice-cyan shell
  ══════════════════════════════════════════ */

  /* Strip frame wrapper chrome — content area already scoped by the P3R shell */
  .sec-scroll :is(.blog-archive-frame, .research-catalog-frame, .gallery-frame, .about-frame) {
    border: none !important;
    background: transparent !important;
    box-shadow: none !important;
    backdrop-filter: none !important;
    border-radius: 0 !important;
    padding: 0 !important;
  }

  /* Page hero card → semi-transparent deep teal glass */
  .sec-scroll :is(.page-hero-card, .blog-overview-card, .research-overview-card) {
    background: var(--p3r-ice-panel-bg) !important;
    border: 1.5px solid var(--p3r-ice-accent-border) !important;
    box-shadow: 0 8px 28px rgba(0,0,0,0.28) !important;
    backdrop-filter: none !important;
  }

  /* Archive note / catalog note */
  .sec-scroll :is(.blog-archive-note, .research-catalog-note) {
    background: var(--p3r-ice-panel-bg-soft) !important;
    border-left-color: var(--p3r-ice-accent) !important;
    border-color: var(--p3r-ice-divider) !important;
  }

  /* Blog / research / gallery entry cards */
  .sec-scroll :is(.blog-entry, .research-entry, .gallery-card, .gallery-item-card, .about-card, .about-friend-card) {
    border-top-color: rgba(49,214,208,0.2) !important;
    background: transparent !important;
    box-shadow: none !important;
    border-color: var(--p3r-ice-divider) !important;
  }

  /* Tags and chips */
  .sec-scroll :is(.blog-entry-tag, .research-entry-tag, .detail-room-tag, .gallery-tag, .about-chip, .gallery-count-chip) {
    background: var(--p3r-ice-chip-bg) !important;
    border-color: var(--p3r-ice-accent-border) !important;
    color: var(--p3r-ice-accent-bright) !important;
    box-shadow: none !important;
  }

  /* Headings and kickers */
  .sec-scroll :is(.page-title, .page-subtitle) { color: #ffffff !important; }
  .sec-scroll :is(
    .blog-archive-kicker, .research-catalog-kicker, .gallery-kicker,
    .blog-overview-label, .research-overview-label, .gallery-label,
    .about-kicker, .about-label,
    .blog-entry-number, .blog-entry-kind,
