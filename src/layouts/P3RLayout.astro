  .sec-scroll hr { border-color: rgba(49,214,208,0.2) !important; }

  /* Buttons and CTAs */
  .sec-scroll :is(.home-primary-link, .about-primary-link) {
    background: var(--p3r-ice-cta-bg) !important;
    color: var(--p3r-ice-white) !important;
