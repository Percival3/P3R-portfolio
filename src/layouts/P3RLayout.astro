</style>

<script>
  type DetailTheme = 'clearing' | 'nocturne';
  const DETAIL_THEME_STORAGE_KEY = 'curved-chaos-detail-theme';
  const mobileShellMq = window.matchMedia('(max-width: 900px)');
  const contentNav = document.getElementById('contentNav') as HTMLElement | null;
  const mobileNavToggle = document.getElementById('mobileNavToggle') as HTMLButtonElement | null;
  const detailThemeDock = document.querySelector<HTMLElement>('.detail-theme-dock');
  const detailThemeToggle = detailThemeDock?.querySelector<HTMLButtonElement>('[data-detail-theme-toggle]') ?? null;
  const detailThemeButtons = [...document.querySelectorAll<HTMLButtonElement>('[data-detail-theme-button]')];

  function syncDisclosureState(container: HTMLElement | null, button: HTMLButtonElement | null, open: boolean) {
    if (!container || !button) return;
    container.classList.toggle('is-mobile-open', open);
    button.setAttribute('aria-expanded', String(open));
  }

  function closeMobilePanels(except?: 'nav' | 'theme') {
    if (except !== 'nav') {
      syncDisclosureState(contentNav, mobileNavToggle, false);
    }
    if (except !== 'theme') {
      syncDisclosureState(detailThemeDock ?? null, detailThemeToggle ?? null, false);
    }
  }

  function syncDetailThemeButtons(theme: DetailTheme) {
    detailThemeButtons.forEach((button) => {
      const active = button.dataset.themeValue === theme;
      button.classList.toggle('is-active', active);
      button.setAttribute('aria-pressed', String(active));
    });
  }

  function setDetailTheme(theme: DetailTheme, persist = true) {
    document.documentElement.dataset.detailTheme = theme;
    syncDetailThemeButtons(theme);
    if (!persist) return;
    try {
      window.localStorage.setItem(DETAIL_THEME_STORAGE_KEY, theme);
    } catch {
      // Ignore storage failures; the active page theme still updates.
    }
  }

  if (detailThemeButtons.length > 0) {
    const initialTheme: DetailTheme = document.documentElement.dataset.detailTheme === 'nocturne'
      ? 'nocturne'
      : 'clearing';
    setDetailTheme(initialTheme, false);
    detailThemeButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const nextTheme: DetailTheme = button.dataset.themeValue === 'nocturne'
          ? 'nocturne'
          : 'clearing';
        if (mobileShellMq.matches) {
          syncDisclosureState(detailThemeDock ?? null, detailThemeToggle ?? null, false);
        }
        if (document.documentElement.dataset.detailTheme === nextTheme) return;
        setDetailTheme(nextTheme);
      });
    });
  }

  mobileNavToggle?.addEventListener('click', (event) => {
    event.stopPropagation();
    if (!mobileShellMq.matches || !contentNav) return;
    const next = !contentNav.classList.contains('is-mobile-open');
    closeMobilePanels(next ? 'nav' : undefined);
    syncDisclosureState(contentNav, mobileNavToggle, next);
  });

  detailThemeToggle?.addEventListener('click', (event) => {
    event.stopPropagation();
    if (!mobileShellMq.matches || !detailThemeDock) return;
    const next = !detailThemeDock.classList.contains('is-mobile-open');
    closeMobilePanels(next ? 'theme' : undefined);
    syncDisclosureState(detailThemeDock, detailThemeToggle, next);
  });

  document.addEventListener('click', (event) => {
    if (!mobileShellMq.matches) return;
    const target = event.target as Node;
    if (contentNav && mobileNavToggle && !contentNav.contains(target) && !mobileNavToggle.contains(target)) {
      syncDisclosureState(contentNav, mobileNavToggle, false);
    }
    if (detailThemeDock && detailThemeToggle && !detailThemeDock.contains(target)) {
      syncDisclosureState(detailThemeDock, detailThemeToggle, false);
    }
  });

  mobileShellMq.addEventListener('change', (event) => {
    if (!event.matches) {
      closeMobilePanels();
    }
  });

  /* ── Ripple + navigation ── */
  const PAGE_TRANSITION_STORAGE_KEY = 'curved-chaos-page-transition-ts';
  const ripple1 = document.getElementById('ripple1') as HTMLElement;
  const ripple2 = document.getElementById('ripple2') as HTMLElement;
  let transitioning = false;

  function primeIncomingTransition() {
    try {
      window.sessionStorage.setItem(PAGE_TRANSITION_STORAGE_KEY, String(Date.now()));
    } catch {
      // Ignore storage failures; the navigation still works.
    }
  }

  function doTransition(x: number, y: number, callback: () => void) {
    if (transitioning) return;
    transitioning = true;

    const maxR = Math.ceil(
      Math.hypot(Math.max(x, window.innerWidth - x), Math.max(y, window.innerHeight - y)),
    ) + 60;

    const at = `${x}px ${y}px`;
    const dur = 540;

    [ripple1, ripple2].forEach((r) => {
      r.style.transition = 'none';
      r.style.clipPath = `circle(0px at ${at})`;
    });
    void ripple1.offsetHeight;
    ripple1.style.transition = `clip-path ${dur}ms cubic-bezier(0.4,0,0.2,1)`;
    ripple2.style.transition = `clip-path ${dur}ms cubic-bezier(0.4,0,0.2,1) 55ms`;
    ripple1.style.clipPath = `circle(${maxR}px at ${at})`;
    ripple2.style.clipPath = `circle(${maxR}px at ${at})`;

    setTimeout(() => {
      primeIncomingTransition();
      callback();
    }, dur);
  }

  /* Arc nav clicks */
  document.querySelectorAll<HTMLAnchorElement>('#contentNav .cnav-item').forEach((link) => {
    if (link.classList.contains('active')) return;
    link.addEventListener('click', (e) => {
      e.preventDefault();
      if (transitioning) return;
      const url = link.dataset.url!;
      doTransition(e.clientX, e.clientY, () => { window.location.href = url; });
    });
  });

  document.querySelectorAll<HTMLAnchorElement>('[data-transition-link="locale"]').forEach((link) => {
    if (link.getAttribute('aria-current') === 'page') return;
    link.addEventListener('click', (e) => {
      e.preventDefault();
      if (transitioning) return;
      const url = link.dataset.url;
      if (!url) return;
      doTransition(e.clientX, e.clientY, () => { window.location.href = url; });
    });
  });

  /* Keyboard */
  const navLinks = [...document.querySelectorAll<HTMLAnchorElement>('#contentNav .cnav-item')];
  document.addEventListener('keydown', (e) => {
    const cx = window.innerWidth / 2, cy = window.innerHeight / 2;
    if (e.key === 'Escape') {
      const homeUrl = document.querySelector<HTMLAnchorElement>('.nav-back')?.href;
      if (homeUrl) doTransition(cx, cy, () => { window.location.href = homeUrl; });
      return;
    }
    if (e.key === 'ArrowUp' || e.key === 'ArrowDown') {
      e.preventDefault();
      const cur = navLinks.findIndex(l => l.classList.contains('active'));
      const next = e.key === 'ArrowUp'
        ? Math.max(0, cur - 1)
        : Math.min(navLinks.length - 1, cur + 1);
      if (next !== cur) {
        const url = navLinks[next].dataset.url!;
        doTransition(cx, cy, () => { window.location.href = url; });
      }
    }
  });

  /* Canvas: particles + energy streaks + glitch lines */
  (function () {
    const canvas = document.getElementById('c-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d')!;
    let W: number, H: number;
    const pts: { x:number; y:number; sz:number; vx:number; vy:number; op:number; cyan:boolean }[] = [];
    const streaks: { x:number; y:number; w:number; op:number }[] = [];
    const glitches: { x:number; y:number; h:number; op:number }[] = [];

    function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
    resize();
    window.addEventListener('resize', resize);
    for (let i = 0; i < 55; i++) spawnPt(true);

    function spawnPt(init: boolean) {
      pts.push({
        x: Math.random() * W,
        y: init ? Math.random() * H : H + 8,
        sz: Math.random() * 3.5 + 1,
        vx: (Math.random() - .5) * .4,
        vy: -(Math.random() * .95 + .28),
        op: Math.random() * .48 + .18,
        cyan: Math.random() > .35,
      });
    }

    function tick() {
      ctx.clearRect(0, 0, W, H);
      for (let i = pts.length - 1; i >= 0; i--) {
        const p = pts[i];
        ctx.beginPath(); ctx.arc(p.x, p.y, p.sz, 0, Math.PI * 2);
        ctx.fillStyle = p.cyan ? `rgba(49,214,208,${p.op})` : `rgba(168,250,246,${p.op})`;
        ctx.fill();
        p.x += p.vx; p.y += p.vy;
        if (p.y < -10) { pts.splice(i, 1); spawnPt(false); }
      }
      if (Math.random() < .009) streaks.push({ y: 80 + Math.random() * (H - 180), x: -160, w: 110 + Math.random() * 220, op: .65 });
      for (let i = streaks.length - 1; i >= 0; i--) {
        const s = streaks[i];
        const g = ctx.createLinearGradient(s.x, 0, s.x + s.w, 0);
        g.addColorStop(0, 'transparent'); g.addColorStop(.5, `rgba(49,214,208,${s.op})`); g.addColorStop(1, 'transparent');
        ctx.fillStyle = g; ctx.fillRect(s.x, s.y - 1, s.w, 2);
        s.x += 17; s.op -= .015;
        if (s.x > W + 160 || s.op <= 0) streaks.splice(i, 1);
      }
      if (Math.random() < .004) glitches.push({ x: Math.random() * W, y: Math.random() * H * .6, h: 30 + Math.random() * 80, op: .55 });
      for (let i = glitches.length - 1; i >= 0; i--) {
        const gl = glitches[i];
        const gg = ctx.createLinearGradient(0, gl.y, 0, gl.y + gl.h);
        gg.addColorStop(0, 'transparent'); gg.addColorStop(.5, `rgba(168,250,246,${gl.op})`); gg.addColorStop(1, 'transparent');
        ctx.fillStyle = gg; ctx.fillRect(gl.x - 1, gl.y, 2, gl.h);
        gl.op -= .022;
        if (gl.op <= 0) glitches.splice(i, 1);
      }
      requestAnimationFrame(tick);
    }
    tick();
  })();

  /* Arc nav size cascade: active → large, adjacent → smaller */
  (function () {
    const items = [...document.querySelectorAll<HTMLElement>('#contentNav .cnav-item')];
    const activeIdx = items.findIndex(el => el.classList.contains('active'));
    const sizes    = [2.1, 1.45];
    const opacities= [0.88, 0.58];
    items.forEach((el, i) => {
      if (el.classList.contains('active')) return;
      const d = Math.min(Math.abs(i - activeIdx) - 1, sizes.length - 1);
      el.style.fontSize = sizes[d] + 'rem';
      el.style.opacity  = String(opacities[d]);
    });
  })();
</script>
