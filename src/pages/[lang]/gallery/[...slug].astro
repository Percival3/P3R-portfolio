---
import P3RLayout from '../../../layouts/P3RLayout.astro';
import { getCollection, render } from 'astro:content';
import { ArrowLeft, ExternalLink, Code } from 'lucide-react';
import { getRelativeLocaleUrl } from 'astro:i18n';

export async function getStaticPaths() {
  const allCreatives = await getCollection('creatives');

  const paths = [];
  const langs = ['zh', 'en', 'ja'];

  for (const item of allCreatives) {
    for (const lang of langs) {
      paths.push({
        params: {
          lang,
          slug: item.id.replace(/\.mdx?$/, ''),
        },
        props: { item },
      });
    }
  }

  return paths;
}

const { item } = Astro.props;
const { lang } = Astro.params;
const { Content } = await render(item);
const canonical = new URL(
  getRelativeLocaleUrl(item.data.lang, `gallery/${item.id.replace(/\.mdx?$/, '')}`),
  Astro.site ?? Astro.url,
).toString();

type CreativeCategory = 'social-observation' | 'anime' | 'other';
const categoryKey = (item.data.category ?? 'other') as CreativeCategory;

const textByLang = {
  zh: {
    back: '返回作品目录',
    kicker: 'CREATIVE RECORD / VIEWING ROOM',
    category: 'Category',
    demo: '在线演示',
    stack: 'Tech stack',
    tags: 'Keywords',
    categories: {
      'social-observation': '社会观察',
      anime: '动画',
      other: '其他专题',
    },
  },
  en: {
    back: 'Back to Gallery',
    kicker: 'CREATIVE RECORD / VIEWING ROOM',
    category: 'Category',
    demo: 'Live Demo',
    stack: 'Tech stack',
    tags: 'Keywords',
    categories: {
      'social-observation': 'Social Observation',
      anime: 'Anime',
      other: 'Other Topics',
    },
  },
  ja: {
    back: 'ギャラリーに戻る',
    kicker: 'CREATIVE RECORD / VIEWING ROOM',
    category: 'Category',
    demo: 'Live Demo',
    stack: 'Tech stack',
    tags: 'Keywords',
    categories: {
      'social-observation': '社会観察',
      anime: 'アニメ',
      other: 'その他',
    },
  },
} as const;

const t = textByLang[lang as keyof typeof textByLang] || textByLang.en;
---

<P3RLayout title={item.data.title} lang={lang} section="gallery" canonical={canonical} detailThemeToggle={true}>
  <div class="record-frame">
      <header class="grid gap-4 border-b border-[rgba(108,82,58,0.1)] p-4 md:grid-cols-[minmax(0,1.16fr)_minmax(260px,0.72fr)] md:p-8">
        <div>
          <a href={getRelativeLocaleUrl(lang, 'gallery')} class="record-back">
            <ArrowLeft className="h-4 w-4" />
            <span>{t.back}</span>
          </a>

          <p class="record-kicker">{t.kicker}</p>
          <div class="record-kind-badge mt-4 inline-flex items-center gap-2 rounded-full px-3 py-2 text-[0.72rem] uppercase tracking-[0.12em]">
            <span>{t.category}</span>
            <span>{t.categories[categoryKey]}</span>
          </div>

          <h1 class="record-title">{item.data.title}</h1>
          <p class="mt-4 max-w-3xl text-base leading-8 text-[rgba(49,35,22,0.9)] dark:text-[rgba(206,223,236,0.78)]">{item.data.description}</p>

          {(item.data.previewImage || item.data.heroImage) && (
            <figure class="record-visual">
              <img src={item.data.previewImage || item.data.heroImage} alt={item.data.title} class="h-full w-full object-cover" />
            </figure>
          )}
        </div>

        <aside class="grid content-start gap-4">
          {item.data.demoUrl && (
            <section class="record-card">
              <p class="record-label">{t.demo}</p>
              <a href={item.data.demoUrl} target="_blank" rel="noreferrer" class="record-resource-link mt-3">
                <span>{t.demo}</span>
                <ExternalLink className="h-3.5 w-3.5" />
              </a>
            </section>
          )}

          {item.data.techStack && item.data.techStack.length > 0 && (
            <section class="record-card">
              <p class="record-label">{t.stack}</p>
              <div class="mt-3 flex flex-wrap gap-2">
                {item.data.techStack.map((tech) => (
                  <span class="record-tag"><Code className="h-3.5 w-3.5" />{tech}</span>
                ))}
              </div>
            </section>
          )}

          {item.data.tags && item.data.tags.length > 0 && (
            <section class="record-card">
              <p class="record-label">{t.tags}</p>
              <div class="mt-3 flex flex-wrap gap-2">
                {item.data.tags.map((tag) => (
                  <span class="record-tag">{tag}</span>
                ))}
              </div>
            </section>
          )}
        </aside>
      </header>

      <section class="p-4 md:p-8">
        <div
          class="record-prose prose prose-lg max-w-none article-prose dark:prose-invert
                 prose-headings:font-bold prose-p:leading-8 prose-li:leading-8
                 prose-a:no-underline hover:prose-a:underline
                 prose-code:before:content-[''] prose-code:after:content-['']
                 prose-img:my-8 prose-img:rounded-[1.35rem]
                 prose-pre:rounded-[1.2rem] prose-pre:shadow-xl
                 prose-blockquote:rounded-r-[1rem]
                 animate-in fade-in slide-in-from-bottom-4 duration-700"
        >
          <Content />
        </div>
      </section>

      <footer class="px-4 pb-6 text-center md:px-8">
        <a href={getRelativeLocaleUrl(lang, 'gallery')} class="record-back">
          <ArrowLeft className="h-4 w-4" />
          <span>{t.back}</span>
        </a>
      </footer>
    </div>
</P3RLayout>

<style>
  .record-back, .record-kicker, .record-label, .record-tag, .record-kind-badge, .record-resource-link { font-family: var(--font-mono-ui); }
  .record-back, .record-kicker, .record-label, .record-tag { text-transform: uppercase; }
  .record-back { display: inline-flex; align-items: center; gap: 0.48rem; margin-bottom: 1rem; font-size: 0.78rem; letter-spacing: 0.08em; color: #302116; text-decoration: none; transition: gap 180ms ease, opacity 180ms ease; }
  .record-back:hover, .record-resource-link:hover { gap: 0.65rem; opacity: 0.82; }
  .record-kicker, .record-label { letter-spacing: 0.17em; color: rgba(78,56,39,0.88); }
  .record-title { margin-top: 0.8rem; max-width: 12ch; font-family: var(--font-display); font-size: clamp(2.7rem, 5.3vw, 4.7rem); line-height: 0.98; letter-spacing: -0.02em; color: #23180f; }
  .record-visual { margin-top: 1.3rem; overflow: hidden; border-radius: 1.4rem; background: #17130f; }
  .record-card { border-radius: 1.25rem; padding: 1rem 1.05rem; }
  .record-resource-link { display: inline-flex; align-items: center; gap: 0.48rem; font-size: 0.76rem; letter-spacing: 0.08em; text-transform: uppercase; color: #302116; text-decoration: none; transition: gap 180ms ease, opacity 180ms ease; }
  .record-tag { display: inline-flex; align-items: center; gap: 0.42rem; border-radius: 999px; padding: 0.42rem 0.72rem; font-size: 0.68rem; letter-spacing: 0.08em; color: rgba(55,39,24,0.88); }
  .record-prose { width: min(100%, 760px); margin: 0 auto; }
  :global(html.dark) .record-back, :global(html.dark) .record-kicker, :global(html.dark) .record-label { color: rgba(171,194,212,0.72); }
  :global(html.dark) .record-title { color: #eef5fb; }
  :global(html.dark) .record-resource-link, :global(html.dark) .record-tag { color: #eaf3fb; }
  .record-prose :global(pre) { padding: 1.25rem !important; overflow-x: auto; }
  .record-prose :global(pre code) { background: transparent !important; padding: 0 !important; }
  .record-prose :global(img) { max-width: 100%; height: auto; display: block; margin-left: auto; margin-right: auto; }
  @media (max-width: 720px) {
    .record-title { font-size: clamp(2.1rem, 11vw, 3rem); }
    .record-prose { width: 100%; }
  }
</style>
