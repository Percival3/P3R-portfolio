---
import P3RLayout from '../../../layouts/P3RLayout.astro';
import { getCollection } from 'astro:content';
import { Calendar, FileText, Database, ExternalLink, BookOpen, ArrowUpRight } from 'lucide-react';
import { getRelativeLocaleUrl } from 'astro:i18n';

export async function getStaticPaths() {
  return [
    { params: { lang: 'zh' } },
    { params: { lang: 'en' } },
    { params: { lang: 'ja' } },
  ];
}

const { lang } = Astro.params;

const allResearch = await getCollection('research');
const published = allResearch
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const papers = published.filter((item) => item.data.type === 'paper');
const datasets = published.filter((item) => item.data.type === 'dataset');

const texts = {
  zh: {
    pageTitle: '研究档案',
    kicker: 'RESEARCH CATALOG / FILED MATERIAL',
    title: '论文、数据与尚未结束的问题意识。',
    subtitle:
      '一些稍微严肃点、符合规范的东西。',
    noteLabel: 'Catalog note',
    note:
      '如果博客是个人思考的流动记录，研究页就应该更像一份被整理过的工作台账。它要克制、清晰，并且允许读者快速判断材料类型与进入方式。',
    countLabel: 'Filed items',
    paperLabel: 'Papers',
    datasetLabel: 'Datasets',
    latestLabel: 'Latest filing',
    noItems: '暂无内容',
    venue: '发表',
    released: '归档',
    paperKind: 'paper',
    datasetKind: 'dataset',
    detailCta: '查看条目',
    pdfCta: 'PDF',
    doiCta: 'DOI',
    datasetCta: 'Dataset',
    tagsLabel: 'Keywords',
  },
  en: {
    pageTitle: 'Research Catalog',
    kicker: 'RESEARCH CATALOG / FILED MATERIAL',
    title: 'Papers, datasets, and questions that remain open.',
    subtitle:
      'Things a little more serious, and made to hold their form.',
    noteLabel: 'Catalog note',
    note:
      'If the blog is a flowing record of thought, the research page should feel like a deliberate ledger of work. It should stay restrained, legible, and explicit about what kind of material each entry contains.',
    countLabel: 'Filed items',
    paperLabel: 'Papers',
    datasetLabel: 'Datasets',
    latestLabel: 'Latest filing',
    noItems: 'No items yet',
    venue: 'Venue',
    released: 'Filed',
    paperKind: 'paper',
    datasetKind: 'dataset',
    detailCta: 'Open record',
    pdfCta: 'PDF',
    doiCta: 'DOI',
    datasetCta: 'Dataset',
    tagsLabel: 'Keywords',
  },
  ja: {
    pageTitle: '研究アーカイブ',
    kicker: 'RESEARCH CATALOG / FILED MATERIAL',
    title: '論文、データ、そしてまだ閉じていない問い。',
    subtitle:
      '少しだけ真面目で、きちんと形式に従ったもの。',
    noteLabel: 'Catalog note',
    note:
      'ブログが思考の流れを記録する場所なら、研究ページは整理された作業台帳であるべきです。抑制が効いていて、読みやすく、各項目の種類と入口が明確であることを優先します。',
    countLabel: 'Filed items',
    paperLabel: 'Papers',
    datasetLabel: 'Datasets',
    latestLabel: 'Latest filing',
    noItems: 'コンテンツはまだありません',
    venue: '掲載先',
    released: '記録日',
    paperKind: 'paper',
    datasetKind: 'dataset',
    detailCta: '項目を見る',
    pdfCta: 'PDF',
    doiCta: 'DOI',
    datasetCta: 'Dataset',
    tagsLabel: 'Keywords',
  },
} as const;

const t = texts[lang as keyof typeof texts] || texts.zh;

function formatDate(date: Date, locale: string): string {
  const localeMap = { zh: 'zh-CN', en: 'en-US', ja: 'ja-JP' };
  return date.toLocaleDateString(localeMap[locale as keyof typeof localeMap] || 'zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const latestDate = published[0]?.data.pubDate;
---

<P3RLayout title={t.pageTitle} lang={lang} section="research">
  <div class="research-catalog-frame">
      <header class="research-catalog-hero">
        <div class="research-catalog-copy">
          <p class="research-catalog-kicker">{t.kicker}</p>
          <h1 class="research-catalog-title">{t.title}</h1>
          <p class="research-catalog-subtitle">{t.subtitle}</p>

        </div>

        <aside class="research-catalog-overview">
          <div class="research-overview-card corner-marks">
            <span class="research-overview-label">{t.countLabel}</span>
            <strong class="research-overview-value">{published.length}</strong>
          </div>

          <div class="research-overview-split">
            <div class="research-overview-card corner-marks">
              <span class="research-overview-label">{t.paperLabel}</span>
              <strong class="research-overview-value">{papers.length}</strong>
            </div>
            <div class="research-overview-card corner-marks">
              <span class="research-overview-label">{t.datasetLabel}</span>
              <strong class="research-overview-value">{datasets.length}</strong>
            </div>
          </div>

          <div class="research-overview-card corner-marks">
            <span class="research-overview-label">{t.latestLabel}</span>
            <strong class="research-overview-date">
              {latestDate ? formatDate(latestDate, lang) : 'N/A'}
            </strong>
          </div>
        </aside>
      </header>

      {published.length > 0 ? (
        <div class="research-catalog-list">
          {published.map((item, index) => {
            const itemUrl = getRelativeLocaleUrl(lang, `research/${item.id.replace(/\.mdx?$/, '')}`);
            const isPaper = item.data.type === 'paper';
            const entryNumber = String(index + 1).padStart(2, '0');

            return (
              <article class="research-entry">
                <div class="research-entry-rail">
                  <span class="research-entry-number">{entryNumber}</span>
                  <span class="research-entry-kind">{isPaper ? t.paperKind : t.datasetKind}</span>
                </div>

                <div class="research-entry-icon">
                  {isPaper ? <BookOpen className="h-5 w-5" /> : <Database className="h-5 w-5" />}
                </div>

                <div class="research-entry-body">
                  <div class="research-entry-meta">
                    <span class="research-entry-meta-item">
                      <Calendar className="h-4 w-4" />
                      <span>{t.released}</span>
                      <time datetime={item.data.pubDate.toISOString()}>
                        {formatDate(item.data.pubDate, lang)}
                      </time>
                    </span>

                    {item.data.venue && (
                      <span class="research-entry-meta-item">
                        <FileText className="h-4 w-4" />
                        <span>{t.venue}</span>
                        <span>{item.data.venue}</span>
                      </span>
                    )}
                  </div>

                  <a href={itemUrl} class="research-entry-title-link">
                    <h2 class="research-entry-title">{item.data.title}</h2>
                  </a>

                  <p class="research-entry-description">{item.data.description}</p>

                  {item.data.tags && item.data.tags.length > 0 && (
                    <div class="research-entry-tags" aria-label={t.tagsLabel}>
                      <span class="research-entry-tags-label">{t.tagsLabel}</span>
                      <div class="research-entry-tag-row">
                        {item.data.tags.map((tag) => (
                          <span class="research-entry-tag">{tag}</span>
                        ))}
                      </div>
                    </div>
                  )}

                  <div class="research-entry-actions">
                    <a href={itemUrl} class="research-entry-link">
                      <span>{t.detailCta}</span>
                      <ArrowUpRight className="h-4 w-4" />
                    </a>

                    {item.data.pdfUrl && (
                      <a href={item.data.pdfUrl} target="_blank" rel="noreferrer" class="research-entry-resource">
                        <FileText className="h-4 w-4" />
                        <span>{t.pdfCta}</span>
                        <ExternalLink className="h-3.5 w-3.5" />
                      </a>
                    )}

                    {item.data.datasetUrl && (
                      <a href={item.data.datasetUrl} target="_blank" rel="noreferrer" class="research-entry-resource">
                        <Database className="h-4 w-4" />
                        <span>{t.datasetCta}</span>
                        <ExternalLink className="h-3.5 w-3.5" />
                      </a>
                    )}

                    {item.data.doi && (
                      <a href={`https://doi.org/${item.data.doi}`} target="_blank" rel="noreferrer" class="research-entry-resource">
                        <span>{t.doiCta}</span>
                        <ExternalLink className="h-3.5 w-3.5" />
                      </a>
                    )}
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      ) : (
        <div class="research-catalog-empty">
          <p>{t.noItems}</p>
        </div>
      )}
    </div>
</P3RLayout>

<style>
  .research-catalog-hero {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.18fr) minmax(280px, 0.72fr);
    gap: 1.35rem;
    padding: clamp(1.2rem, 3vw, 2rem);
    border-bottom: 1px solid rgba(108, 82, 58, 0.1);
  }

  .research-catalog-kicker,
  .research-catalog-note-label,
  .research-overview-label,
  .research-entry-number,
  .research-entry-kind,
  .research-entry-tags-label,
  .research-entry-meta,
  .research-entry-link,
  .research-entry-resource,
  .research-entry-tag {
    font-family: var(--font-mono-ui);
  }

  .research-catalog-kicker,
  .research-catalog-note-label,
  .research-overview-label,
  .research-entry-number,
  .research-entry-kind,
  .research-entry-tags-label {
    text-transform: uppercase;
    letter-spacing: 0.17em;
  }

  .research-catalog-kicker {
    font-size: 0.73rem;
    color: rgba(78, 56, 39, 0.88);
  }

  .research-catalog-title {
    margin-top: 0.7rem;
    max-width: 12ch;
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 5.2vw, 4.5rem);
    line-height: 0.98;
    letter-spacing: -0.02em;
    color: #23180f;
    text-wrap: balance;
  }

  .research-catalog-subtitle {
    max-width: 46rem;
    margin-top: 1rem;
    font-size: clamp(1rem, 1.35vw, 1.14rem);
    line-height: 1.9;
    color: rgba(49, 35, 22, 0.9);
    text-wrap: pretty;
  }

  .research-catalog-note {
    margin-top: 1.45rem;
    max-width: 41rem;
    padding: 1rem 1.1rem;
    border-radius: 1.25rem;
    border-left-width: 2px;
  }

  .research-catalog-note-label {
    font-size: 0.66rem;
    color: rgba(84, 61, 42, 0.84);
  }

  .research-catalog-note-text {
    margin-top: 0.55rem;
    font-size: 0.96rem;
    line-height: 1.8;
    color: rgba(51, 36, 23, 0.88);
  }

  .research-catalog-overview {
    display: grid;
    gap: 0.9rem;
    align-content: start;
  }

  .research-overview-split {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .research-overview-card {
    border-radius: 1.25rem;
    padding: 1rem 1.05rem;
    border: 1px solid transparent;
    transition: border-color 220ms ease, box-shadow 220ms ease;
  }

  .research-overview-card:hover {
    border-color: var(--component-accent-border-strong);
    box-shadow: var(--component-accent-hover-shadow);
  }

  .research-overview-label {
    display: block;
    font-size: 0.64rem;
    color: rgba(84, 61, 42, 0.82);
  }

  .research-overview-value,
  .research-overview-date {
    display: block;
    margin-top: 0.48rem;
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 2.8vw, 2.25rem);
    line-height: 1.05;
    color: #24180f;
  }

  .research-overview-date {
    font-size: 1.12rem;
    line-height: 1.55;
  }

  .research-catalog-list {
    position: relative;
    z-index: 1;
    display: grid;
  }

  .research-entry {
    display: grid;
    grid-template-columns: 72px 48px minmax(0, 1fr);
    gap: 1rem;
    padding: 1.35rem clamp(1.2rem, 3vw, 2rem);
    border-top: 1px solid rgba(108, 82, 58, 0.1);
  }

  .research-entry-rail {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding-top: 0.18rem;
  }

  .research-entry-number {
    font-size: 0.78rem;
    color: rgba(88, 64, 45, 0.84);
  }

  .research-entry-kind {
    font-size: 0.62rem;
    color: rgba(93, 69, 48, 0.74);
  }

  .research-entry-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    margin-top: 0.15rem;
    border-radius: 1rem;
    color: #35251a;
  }

  .research-entry-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem 1rem;
    font-size: 0.78rem;
    letter-spacing: 0.02em;
    color: rgba(82, 60, 41, 0.82);
  }

  .research-entry-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .research-entry-title-link {
    display: inline-block;
    margin-top: 0.75rem;
    color: inherit;
    text-decoration: none;
  }

  .research-entry-title {
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 2.8vw, 2.45rem);
    line-height: 1.02;
    color: #22170e;
    transition: opacity 180ms ease;
  }

  .research-entry-title-link:hover .research-entry-title {
    opacity: 0.82;
  }

  .research-entry-description {
    max-width: 48rem;
    margin-top: 0.7rem;
    font-size: 1rem;
    line-height: 1.82;
    color: rgba(51, 36, 23, 0.88);
    text-wrap: pretty;
  }

  .research-entry-tags {
    display: grid;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .research-entry-tags-label {
    font-size: 0.62rem;
    color: rgba(84, 61, 42, 0.82);
  }

  .research-entry-tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .research-entry-tag {
    border-radius: 999px;
    padding: 0.42rem 0.72rem;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: rgba(55, 39, 24, 0.88);
  }

  .research-entry-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 1rem;
    margin-top: 1rem;
  }

  .research-entry-link,
  .research-entry-resource {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: gap 180ms ease, opacity 180ms ease, color 180ms ease;
  }

  .research-entry-link {
    color: #2c2016;
  }

  .research-entry-link:hover,
  .research-entry-resource:hover {
    gap: 0.62rem;
    opacity: 0.82;
  }

  .research-entry-resource {
    color: rgba(71, 52, 34, 0.76);
  }

  .research-catalog-empty {
    position: relative;
    z-index: 1;
    padding: 2rem;
    color: rgba(63, 47, 32, 0.72);
    text-align: center;
  }

  :global(html.dark) .research-catalog-hero,
  :global(html.dark) .research-entry {
    border-color: rgba(95, 123, 150, 0.14);
  }

  :global(html.dark) .research-catalog-kicker,
  :global(html.dark) .research-catalog-note-label,
  :global(html.dark) .research-overview-label,
  :global(html.dark) .research-entry-number,
  :global(html.dark) .research-entry-kind,
  :global(html.dark) .research-entry-tags-label {
    color: rgba(171, 194, 212, 0.72);
  }

  :global(html.dark) .research-catalog-title,
  :global(html.dark) .research-overview-value,
  :global(html.dark) .research-overview-date,
  :global(html.dark) .research-entry-title {
    color: #eef5fb;
  }

  :global(html.dark) .research-catalog-subtitle,
  :global(html.dark) .research-catalog-note-text,
  :global(html.dark) .research-entry-description,
  :global(html.dark) .research-catalog-empty {
    color: rgba(206, 223, 236, 0.78);
  }

  :global(html.dark) .research-entry-icon {
    color: #ebf4fb;
  }

  :global(html.dark) .research-entry-meta,
  :global(html.dark) .research-entry-resource {
    color: rgba(167, 194, 216, 0.74);
  }

  :global(html.dark) .research-entry-tag {
    color: rgba(214, 227, 238, 0.78);
  }

  :global(html.dark) .research-entry-link {
    color: #eaf3fb;
  }

  @media (max-width: 980px) {
    .research-catalog-hero {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .research-catalog-hero {
      gap: 1rem;
      padding: 1rem;
    }

    .research-catalog-title {
      max-width: none;
      font-size: clamp(2.1rem, 11vw, 3rem);
    }

    .research-catalog-subtitle,
    .research-catalog-note-text,
    .research-entry-description {
      font-size: 0.95rem;
      line-height: 1.74;
    }

    .research-catalog-overview {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
    }

    .research-overview-card:first-child {
      grid-column: 1 / -1;
    }

    .research-overview-card {
      min-height: 6.6rem;
      padding: 0.9rem;
    }

    .research-overview-split {
      grid-template-columns: 1fr 1fr;
    }

    .research-entry {
      grid-template-columns: auto minmax(0, 1fr);
      gap: 0.75rem 0.9rem;
      padding: 1rem;
      align-items: start;
    }

    .research-entry-rail {
      grid-column: 1 / -1;
      flex-direction: row;
      align-items: center;
      gap: 0.5rem;
      padding-top: 0;
    }

    .research-entry-icon {
      grid-column: 1;
      grid-row: 2;
      width: 2.55rem;
      height: 2.55rem;
      margin-top: 0.12rem;
      border-radius: 0.85rem;
    }

    .research-entry-body {
      grid-column: 2;
      grid-row: 2;
      min-width: 0;
    }

    .research-entry-meta {
      gap: 0.55rem 0.8rem;
      font-size: 0.72rem;
    }

    .research-entry-meta-item {
      gap: 0.35rem;
    }

    .research-entry-title {
      font-size: clamp(1.45rem, 7.6vw, 1.85rem);
    }

    .research-entry-actions {
      gap: 0.5rem 0.75rem;
    }
  }

  @media (max-width: 420px) {
    .research-catalog-overview {
      grid-template-columns: 1fr;
    }

    .research-overview-card:first-child {
      grid-column: auto;
    }

    .research-entry {
      grid-template-columns: 1fr;
    }

    .research-entry-icon,
    .research-entry-body {
      grid-column: auto;
      grid-row: auto;
    }
  }
</style>
